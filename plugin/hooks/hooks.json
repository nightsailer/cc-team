{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m cc_team.hooks.stop",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 -m cc_team.hooks.statusline",
    "padding": 2
  }
}
